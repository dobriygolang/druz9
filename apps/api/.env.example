POSTGRES_DB=back
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
DATABASE_URL=postgres://postgres:postgres@localhost:5432/back?sslmode=disable
S3_ENDPOINT=http://localhost:9010
S3_PUBLIC_ENDPOINT=http://localhost:9010
S3_BUCKET=back-local
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=druz9_bot
AI_REVIEW_API_KEY=
AI_REVIEW_PROVIDER=gemini
AI_REVIEW_MODEL=gemini-2.5-flash
AI_REVIEW_BASE_URL=https://generativelanguage.googleapis.com
AI_REVIEW_TIMEOUT=30s
AI_REVIEW_MAX_IMAGE_BYTES=5242880

# OpenRouter example:
# AI_REVIEW_PROVIDER=openai_compatible
# AI_REVIEW_MODEL=openai/gpt-4.1-mini
# AI_REVIEW_BASE_URL=https://openrouter.ai/api/v1
# AI_REVIEW_API_KEY=sk-or-...
CONFIG_PROFILE=local
SANDBOX_MODE=remote
SANDBOX_RUNNER_URL=http://localhost:8098
SANDBOX_RUNNER_TIMEOUT=25s

# Boosty premium subscription verification.
# Extract tokens from browser DevTools → Application → LocalStorage on boosty.to.
BOOSTY_BLOG_NAME=
BOOSTY_ACCESS_TOKEN=
BOOSTY_REFRESH_TOKEN=
BOOSTY_DEVICE_ID=
BOOSTY_TIMEOUT=15s

# Secrets and runtime connection params are loaded from env or *_FILE.
# .platform/values_<profile>.yaml should contain only non-secret config.
