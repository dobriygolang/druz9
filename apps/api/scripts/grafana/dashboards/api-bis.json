          "refId": "C",
          "expr": "sum(rate(business_matches_started_total[5m]))",
          "legendFormat": "matches started"
        },
        {
          "refId": "D",
          "expr": "sum(rate(business_matches_finished_total[5m]))",
          "legendFormat": "matches finished"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 8,
      "title": "Submissions Flow",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(business_submissions_total[5m]))",
          "legendFormat": "submitted"
        },
        {
          "refId": "B",
          "expr": "sum(rate(business_submissions_accepted_total[5m]))",
          "legendFormat": "accepted"
        },
        {
          "refId": "C",
          "expr": "sum(rate(business_submissions_rejected_total[5m]))",
          "legendFormat": "rejected"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 9,
      "title": "Submission Acceptance %",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(business_submissions_accepted_total[5m])) / clamp_min(sum(rate(business_submissions_total[5m])), 0.0001) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "green", "value": 70 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 10,
      "title": "Match Completion %",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(business_matches_finished_total[5m])) / clamp_min(sum(rate(business_matches_started_total[5m])), 0.0001) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 11,
      "title": "Avg Players per Room",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
