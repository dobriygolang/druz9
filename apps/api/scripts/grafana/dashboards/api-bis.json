      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum(rate(business_podcast_listen_total[5m])) by (podcast_title)) / clamp_min(sum(rate(business_podcast_listen_total[5m])), 0.0001) * 100",
          "legendFormat": "{{podcast_title}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "stacking": { "mode": "percent", "group": "A" },
            "fillOpacity": 20
